/* ===== DESKTOP: phone-width device on the ember page ===== */
@media(min-width:900px){
  body{align-items:center !important;background:radial-gradient(120% 70% at 82% 2%,rgba(255,170,0,.10),transparent 55%),radial-gradient(100% 60% at 8% 100%,rgba(90,110,255,.05),transparent 55%),#0A0805 !important;}
