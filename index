// ---- Smart "Today" briefing (computed from real data; AI-upgraded when available) ----
async function buildBriefing(){
  if(!currentUser)return '';
  var parts=[];
  try{
    var wantTasks=enabledTabs().indexOf('work')>=0;
    var res=await Promise.all([getCountdowns(),getMeals(),wantTasks?loadItems('work'):Promise.resolve([])]);
    var cds=res[0]||[],meals=res[1]||{},tasks=res[2]||[];
    var today=new Date();today.setHours(0,0,0,0);
    var soon=null,sd=null;
    cds.forEach(function(c){if(!c.d)return;var dt=new Date(c.d+'T00:00:00');if(isNaN(dt.getTime()))return;var days=Math.round((dt-today)/86400000);if(days>=0&&(sd===null||days<sd)){sd=days;soon=c;}});
    if(soon){var nm=soon.n||'Countdown';parts.push(sd===0?nm+' today':sd===1?nm+' tomorrow':nm+' in '+sd+' days');}
    var dn=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][new Date().getDay()];
    var dinner=meals[dn]&&meals[dn].d;
    if(dinner)parts.push('Dinner: '+dinner);
    if(tasks&&tasks.length)parts.push(tasks.length+' task'+(tasks.length>1?'s':''));
  }catch(e){}
  return parts.slice(0,3).join('   ·   ');
}
function refreshBriefing(){
  buildBriefing().then(function(t){
    if(!t)return;                              // nothing to show → keep current text
    lsSet('forge.brief',t);
    var els=document.querySelectorAll('#briefLine');
    for(var i=0;i<els.length;i++)els[i].textContent=t;
  }).catch(function(){});
}
