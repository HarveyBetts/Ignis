// Live cross-device tab sync via Supabase Realtime
var _tabsChannel=null;
function handleSettingsChange(payload){
  try{
    var row=(payload&&(payload.new||payload.record))||null;
    if(!row||row.enabled_tabs==null)return;
    var arr=typeof row.enabled_tabs==='string'?JSON.parse(row.enabled_tabs):row.enabled_tabs;
    if(!Array.isArray(arr))return;
    var before=JSON.stringify(enabledTabs());
    _tabsCache=arr;lsSet(tabsKey(),JSON.stringify(arr));
    if(JSON.stringify(enabledTabs())===before)return;        // no real change (e.g. our own echo)
    if(typeof current!=='undefined'&&current){ if(current.tab===null)go(null,true); else refreshScreen(); }
  }catch(e){}
}
function subscribeTabs(){
  if(!currentUser||!sb.channel)return;
  if(_tabsChannel){try{sb.removeChannel(_tabsChannel);}catch(e){}_tabsChannel=null;}
  try{
    _tabsChannel=sb.channel('forge-settings-'+currentUser.id)
      .on('postgres_changes',{event:'*',schema:'public',table:'settings',filter:'user_id=eq.'+currentUser.id},handleSettingsChange)
      .subscribe();
  }catch(e){}
}
