    '<div class="card"><div class="ctitle">Logins this week</div>'+weekHtml+'<div class="note">'+icon('clock',13)+'<div>A weekly Monday 9am email is set up via Supabase (see setup steps) — this shows the same data live.</div></div></div>'+
    '<div class="card"><div class="ctitle">Members</div>'+pHtml+'<button class="reqbtn" onclick="openAddUser()" style="margin-top:12px">'+icon('plus',16)+' Add a user</button></div>'+
    '<div class="card"><div class="ctitle">Feature requests</div>'+rHtml+'<div class="note">'+icon('send',13)+'<div>New requests email you at '+esc(OWNER_EMAIL)+' once the email function is deployed.</div></div></div>'+
    '<div class="card"><div class="ctitle">Invite someone</div><div class="rs" style="margin-bottom:10px">Share a personal invite link to Ignis.</div><button class="btn btn-primary" onclick="copyInvite()" style="width:100%">'+icon('share',16)+' Copy invite link</button></div></div>';
}
function copyInvite(){
  var who=encodeURIComponent(currentUser?currentUser.name:'a friend');
  var url=location.origin+location.pathname+'?invite='+who;
  if(navigator.share){navigator.share({title:'Ignis',text:'You\'re invited to Ignis — an app built by Harvey Betts',url:url}).catch(function(){});return;}
  if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(url).then(function(){toast('Invite link copied ✓');},function(){prompt('Copy this link:',url);});}
  else prompt('Copy this link:',url);
}

// ============================================================
// INVITE LANDING (task #15)
// ============================================================
function inviteName(){var m=(location.search+'&'+location.hash).match(/invite=([^&#]+)/);return m?decodeURIComponent(m[1].replace(/\+/g,' ')):null;}
function showInvite(){
  var who=inviteName();
  var v=document.createElement('div');v.className='invite-screen';v.id='invite';
  v.innerHTML='<div class="glow"></div><div class="inv-card"><div class="inv-mark"><img src="'+ICON_SRC+'" alt="Ignis"/></div><div class="inv-tag">You\'re personally invited</div><div class="inv-h">Welcome to Ignis</div><div class="inv-sub">An app built by Harvey Betts'+(who&&who.toLowerCase()!=='a friend'?(' — invited by '+esc(who)):'')+'.</div><div class="inv-steps"><div class="inv-step"><span>1</span><div>Tap the <b>Share</b> icon in your browser</div></div><div class="inv-step"><span>2</span><div>Choose <b>Add to Home Screen</b></div></div><div class="inv-step"><span>3</span><div>Open Ignis from your home screen like a real app</div></div></div><button class="signup-btn" id="invGo" style="margin-top:24px">Continue</button></div>';
  document.getElementById('app').appendChild(v);
  document.getElementById('invGo').onclick=function(){v.classList.add('hide');setTimeout(function(){if(v.parentNode)v.parentNode.removeChild(v);showPinScreen();},560);};
}

// ============================================================
// SIZING / ZOOM LOCK (tasks #3, #4, #14)
// ============================================================
function sizeApp(){var vv=window.visualViewport;var h=(vv&&vv.height)?vv.height:window.innerHeight;var kb=vv?Math.max(0,Math.round(window.innerHeight-vv.height-vv.offsetTop)):0;var ah=(kb>60)?window.innerHeight:h;document.documentElement.style.setProperty('--app-h',ah+'px');var app=document.getElementById('app');if(app)app.style.height=ah+'px';var home=document.querySelector('.screen.is-home');if(home)layoutHome(home);}
window.addEventListener('resize',sizeApp);
// Re-pull cloud tabs whenever the app regains focus, so devices stay identical
document.addEventListener('visibilitychange',function(){
  if(document.visibilityState==='visible'&&currentUser){
    var before=JSON.stringify(enabledTabs());
    loadTabs().then(function(){
      if(JSON.stringify(enabledTabs())!==before&&current&&current.tab===null){go(null,true);}
    });
  }
});
if(window.visualViewport){window.visualViewport.addEventListener('resize',sizeApp);window.visualViewport.addEventListener('scroll',sizeApp);}
window.addEventListener('orientationchange',function(){setTimeout(sizeApp,180);setTimeout(sizeApp,400);});
// block pinch-zoom + double-tap-zoom (lock like a native app)
document.addEventListener('gesturestart',function(e){e.preventDefault();},{passive:false});
document.addEventListener('gesturechange',function(e){e.preventDefault();},{passive:false});
document.addEventListener('gestureend',function(e){e.preventDefault();},{passive:false});
var _lastTouch=0;
document.addEventListener('touchend',function(e){var now=Date.now();if(now-_lastTouch<=300){e.preventDefault();}_lastTouch=now;},{passive:false});
document.addEventListener('dblclick',function(e){e.preventDefault();},{passive:false});
document.addEventListener('wheel',function(e){if(e.ctrlKey)e.preventDefault();},{passive:false});
document.addEventListener('keydown',function(e){if((e.ctrlKey||e.metaKey)&&['+','-','=','0'].indexOf(e.key)>=0)e.preventDefault();});

// ============================================================
// BOOT (tasks #13, #16, #18) — intro → PIN/invite, no flash
// ============================================================
(function(){
  try{var __sq=new URLSearchParams(location.search);if(__sq.get('code')&&(__sq.get('scope')||'').indexOf('activity')>=0){window.__stravaCode=__sq.get('code');history.replaceState({},'',location.origin+location.pathname);}}catch(e){}
  applyTheme();
  sizeApp();
  // animate intro letters
  var w=document.getElementById('introWord');
  'IGNIS'.split('').forEach(function(ch,i){var s=document.createElement('span');s.textContent=ch;s.style.animationDelay=(0.55+i*0.1)+'s';w.appendChild(s);});
  var fromInvite=/(?:[?&#])invite/.test(location.search+location.hash);
  // Build the home screen UNDER the intro so there's no flash when intro lifts.
  // But we must NOT show home until authed — so we only mount the intro now,
  // and reveal PIN exactly as the intro lifts (fixes glitch #13).
  setTimeout(async function(){
    var intro=document.getElementById('intro');
    var fromInvite=/(?:[?&#])invite/.test(location.search+location.hash);
    try{
      if(/type=recovery/.test(location.hash)){ showResetPassword(); }
      else {
        var sres=await sb.auth.getSession();
        var session=sres&&sres.data&&sres.data.session;
        if(session){
          var prof=await resolveProfile();
          if(prof){ currentUser={id:prof.id,name:prof.name,role:prof.role,avatar_url:prof.avatar_url};
            if(lsGet(pinKey(prof.id))){ showPinUnlock(); } else { showSetPin(false); } }
          else { showAuthLogin(); }
        } else if(fromInvite){ showAuthSignup(); }
        else { showAuthLogin(); }
      }
    }catch(e){ showAuthLogin(); }
    intro.classList.add('hide');
    setTimeout(function(){if(intro&&intro.parentNode)intro.parentNode.removeChild(intro);},720);
  },4200); // longer, more premium load (task #16/#18)
})();

(function(){
  var vv=window.visualViewport;
  function intoView(el){if(!el)return;try{el.scrollIntoView({block:'nearest'});}catch(_){}}
  document.addEventListener('focusin',function(e){var t=e.target;if(t&&(t.tagName==='INPUT'||t.tagName==='TEXTAREA')){setTimeout(function(){intoView(t);},320);}});
  if(vv){var apply=function(){var kb=Math.max(0,Math.round(window.innerHeight-vv.height-vv.offsetTop));document.documentElement.style.setProperty('--kb',kb+'px');sizeApp();var lift=kb>60?('translateY(-'+kb+'px)'):'';var sh=document.querySelector('.overlay .sheet');if(sh){sh.style.transition='transform .2s ease';sh.style.transform=lift;}var bar=document.querySelector('.ai-bar');if(bar){bar.style.transition='transform .2s ease';bar.style.transform=lift;}if(kb>60){var ae=document.activeElement;if(ae&&(ae.tagName==='INPUT'||ae.tagName==='TEXTAREA'))setTimeout(function(){intoView(ae);},60);}};vv.addEventListener('resize',apply);vv.addEventListener('scroll',apply);}
})();
</script>
