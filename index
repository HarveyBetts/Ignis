  var sys=persona+'\n\n'+(opts.contract||'')+'\n\nEVERYTHING YOU KNOW ABOUT '+first.toUpperCase()+':\n'+ctx;
  var ans=await askAI([{role:'user',content:task}],sys,opts.maxTokens||1200);
  if(opts.json){
    var jm=ans.match(/```(?:json|forge)?\s*([\s\S]*?)```/i);var raw=jm?jm[1]:ans;
    try{return JSON.parse(raw.trim());}catch(e){try{return JSON.parse((raw.match(/[\[{][\s\S]*[\]}]/)||[''])[0]);}catch(e2){return null;}}
  }
