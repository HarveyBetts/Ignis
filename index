async function renderFuel(){
  var pr=await getFuelProfile();
  if(fuelEditing||!pr||!pr.weight_kg||!pr.goal)return fuelOnboardHTML(pr||{});
  var base={kcal:pr.target_kcal,protein:pr.target_protein,carbs:pr.target_carbs,fat:pr.target_fat};
