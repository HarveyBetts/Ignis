function resetUserPin(id){
  if(!confirm('Reset this person\u2019s PIN?\n\nThey\u2019ll get a one-time temporary code, then set their own private PIN on next login \u2014 which you won\u2019t see.'))return;
  (async function(){
    var temp=String(Math.floor(1000+Math.random()*9000));
    try{
      var hash=await sha256hex(temp);
      await ownerResetPin(id,hash);
      await markPinReset(id);
