async function rcParseGarmin(text){
  try{
    var lines=text.split(/\r?\n/).filter(function(l){return l.trim();});
    if(lines.length<2){toast('That file looks empty');return;}
    var hdr=rcCsvRow(lines[0]).map(function(h){return h.toLowerCase().trim();});
    function idx(names){for(var i=0;i<hdr.length;i++)for(var j=0;j<names.length;j++)if(hdr[i].indexOf(names[j])>=0)return i;return -1;}
