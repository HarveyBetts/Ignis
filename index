function renderPinDots(){var d=document.getElementById('pinDots');if(!d)return;d.className='dots';d.innerHTML='';for(var i=0;i<4;i++){var x=document.createElement('div');x.className='dot-pin';d.appendChild(x);}updateDots();}
function updateDots(){var d=document.getElementById('pinDots');if(!d)return;var ch=d.children;for(var i=0;i<ch.length;i++)ch[i].className='dot-pin'+(i<pinEntry.length?' on':'');}
function buildKeypad(){
  var kp=document.getElementById('keypad');if(!kp)return;kp.innerHTML='';
  ['1','2','3','4','5','6','7','8','9','','0','del'].forEach(function(k){
    var b=document.createElement('button');
    if(k===''){b.className='key blank';}
    else if(k==='del'){b.className='key fn';b.textContent='Delete';bindKey(b,pinDel);}
    else{b.className='key';b.textContent=k;bindKey(b,(function(n){return function(){pinPush(n);};})(k));}
    kp.appendChild(b);
  });
}
function bindKey(b,fn){b.addEventListener('pointerdown',function(e){e.preventDefault();fn();},{passive:false});}
// physical keyboard support for the PIN screen (desktop)
document.addEventListener('keydown',function(e){
  var kp=document.getElementById('keypad');
  if(!kp||!authEl||authEl.style.display==='none')return;                 // only when the PIN keypad is showing
  var ae=document.activeElement; if(ae&&/^(INPUT|TEXTAREA)$/.test(ae.tagName))return;  // don't hijack typed fields
  if(e.key>='0'&&e.key<='9'){e.preventDefault();pinPush(e.key);}
  else if(e.key==='Backspace'){e.preventDefault();pinDel();}
});
function pinPush(n){if(pinBusy||pinEntry.length>=4)return;pinEntry+=n;updateDots();if(pinEntry.length===4){pinBusy=true;setTimeout(pinSubmit,120);}}
function pinDel(){if(pinBusy)return;pinEntry=pinEntry.slice(0,-1);updateDots();}
function pinError(){var d=document.getElementById('pinDots');if(d)d.classList.add('err');if(navigator.vibrate)navigator.vibrate(80);setTimeout(function(){pinEntry='';pinBusy=false;if(d)d.classList.remove('err');updateDots();},440);}
async function pinSubmit(){
  if(pinMode==='set'){
    if(pinSetStage===0){
      pinSetFirst=pinEntry;pinEntry='';pinSetStage=1;pinBusy=false;
      var t=document.getElementById('spTitle'),s=document.getElementById('spSub');
      if(t)t.textContent='Confirm your PIN';if(s)s.textContent='Enter it once more to confirm.';
      updateDots();return;
    }else{
      if(pinEntry===pinSetFirst){
        var hash=await sha256hex(pinEntry);
        lsSet(pinKey(currentUser.id),hash);
        await loadTabs();enterApp(pinSetNew);
      }else{
        pinSetStage=0;pinSetFirst='';
        var t2=document.getElementById('spTitle'),s2=document.getElementById('spSub');
        if(t2)t2.textContent='Set a quick PIN';if(s2)s2.textContent='Didn\u2019t match \u2014 try again.';
        pinError();
      }
      return;
    }
  }
  // unlock mode — compare to this device's stored PIN
  var h=await sha256hex(pinEntry);
  if(currentUser&&lsGet(pinKey(currentUser.id))===h){await loadTabs();enterApp(false);}
  else{pinError();}
}


