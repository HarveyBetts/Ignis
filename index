    if(el&&p&&p.plan&&p.plan.detail){
      var days=p.plan.detail.days||[];var td=runToday();var s=null;
      for(var i=0;i<days.length;i++){if((days[i].day||'')===td){s=days[i];break;}}
      if(s){var t=(s.type||'').toLowerCase();el.textContent=(t==='rest')?'Today \u00B7 rest & recover':('Today \u00B7 '+(s.title||s.type)+(s.km?' \u00B7 '+s.km+' km':''));}
    }
  }catch(e){}
  try{
    var prof=await getFuelProfile();var fel=document.getElementById('homeFuelStat');
    if(fel&&prof){
      var tgt=prof.target_kcal||(prof.weight_kg?fuelTargets(prof).kcal:0);
