function fuelTargets(pr){var kg=pr.weight_kg,cm=pr.height_cm||178,age=pr.age||30,sex=pr.sex||'m';var bmr=10*kg+6.25*cm-5*age+(sex==='m'?5:-161);var tdee=bmr*1.55;var pgmap={ripped:2.0,lean:1.9,maintain:1.8,build:2.0};var adj={ripped:-420,lean:-220,maintain:0,build:260};var kcal=Math.round((tdee+(adj[pr.goal]||0))/10)*10;var protein=Math.round(kg*(pgmap[pr.goal]||1.8));var fat=Math.round(kg*0.9);var carbs=Math.max(60,Math.round((kcal-protein*4-fat*9)/4));return {kcal:kcal,protein:protein,carbs:carbs,fat:fat};}
async function fuelFlex(base){var add={kcal:0,carbs:0,note:'Rest / easy day - base fuelling. Hit your protein to hold muscle.'};try{var rp=await getRunPlan();if(rp&&rp.plan&&rp.plan.detail&&rp.plan.detail.days){var td=runToday();var s=null;rp.plan.detail.days.forEach(function(d){if((d.day||'')===td)s=d;});if(s){var ty=(s.type||'').toLowerCase();var km=s.km||0;if(ty.indexOf('long')>=0||km>=12){add={kcal:450,carbs:90,note:'Long run day - carb up beforehand and refuel within the hour after.'};}else if(ty.indexOf('threshold')>=0||ty.indexOf('interval')>=0||ty.indexOf('vo2')>=0||ty.indexOf('tempo')>=0||ty.indexOf('rep')>=0){add={kcal:350,carbs:70,note:'Quality session - extra carbs to fuel the hard efforts and recover.'};}else if(km>0){add={kcal:220,carbs:45,note:'Easy run day - a little extra fuel around your run.'};}else if(ty.indexOf('strength')>=0){add={kcal:140,carbs:20,note:'Gym day - push protein and time some carbs around the session.'};}}}}catch(e){}return {kcal:base.kcal+add.kcal,protein:base.protein,carbs:base.carbs+add.carbs,fat:base.fat,note:add.note,addKcal:add.kcal};}
