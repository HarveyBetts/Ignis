// ---- Pace & prediction engine (deterministic, from real data) ----
function rcEngine(b){
  if(!b||!b.distance_m||!b.time_s)return null;
  var d1=b.distance_m,t1=b.time_s;
  function riegel(d2){return t1*Math.pow(d2/d1,1.06);}
  var pred={'5K':riegel(5000),'10K':riegel(10000),'Half':riegel(21097.5),'Marathon':riegel(42195)};
  var p5=pred['5K']/5,p10=pred['10K']/10,pH=pred['Half']/21.0975,pM=pred['Marathon']/42.195;
  var paces={fiveK:Math.round(p5),tenK:Math.round(p10),threshold:Math.round((p10+pH)/2),marathon:Math.round(pM),easy:Math.round(pM+70),long:Math.round(pM+52),recovery:Math.round(pM+100),interval:Math.round(p5-6),rep:Math.round(p5-18)};
  return {predictions:pred,paces:paces,benchmark:b};
}
// Best recent effort from logged/Garmin runs → benchmark for the engine
function rcEngineFromLogs(logs){
  var best=null;(logs||[]).forEach(function(l){if(l.km&&l.km>=3&&l.min){var pace=l.min*60/l.km;if(!best||pace<best.pace)best={pace:pace,km:l.km,min:l.min};}});
